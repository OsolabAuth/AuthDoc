        {
          "entity": {
            "type": "Scenario",
            "description": "Creates an MFA step-up token, registers an agent with the current implementation, and gets an agent token.",
            "id": "d03098d1-2fd5-4d15-9dd8-5f79c94353cf",
            "name": "02. MFA to agent token"
          }
        },
        {
          "entity": {
            "type": "Request",
            "method": {
              "requestBody": true,
              "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
              "name": "POST"
            },
            "body": {
              "bodyType": "Text",
              "textBody": "{\n  \"email\": \"${\"email\"}\"\n}"
            },
            "uri": {
              "query": {
                "delimiter": "&",
                "items": []
              },
              "host": "${\"AuthServer\"}",
              "path": "/mfa/email/start"
            },
            "id": "d4df87bb-ec82-45eb-b55d-263d1a7b0f33",
            "name": "01. Start email MFA",
            "headers": [
              {
                "enabled": true,
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "entity": {
            "type": "Request",
            "method": {
              "requestBody": true,
              "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
              "name": "POST"
            },
            "body": {
              "bodyType": "Text",
              "textBody": "{\n  \"email\": \"${\"email\"}\",\n  \"code\": \"${getEntityById(\"d4df87bb-ec82-45eb-b55d-263d1a7b0f33\").\"response\".\"body\".\"code\"}\"\n}"
            },
            "uri": {
              "query": {
                "delimiter": "&",
                "items": []
              },
              "host": "${\"AuthServer\"}",
              "path": "/mfa/email/verify"
            },
            "id": "9f91d9df-16d9-463b-98dd-383ad10a7939",
            "name": "02. Verify email MFA",
            "headers": [
              {
                "enabled": true,
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "entity": {
            "type": "Request",
            "method": {
              "requestBody": true,
              "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
              "name": "POST"
            },
            "body": {
              "bodyType": "Text",
              "textBody": "{\n  \"owner_email\": \"${\"email\"}\",\n  \"agent_name\": \"${\"agentName\"}\",\n  \"client_id\": \"${\"clientId\"}\",\n  \"scope\": \"${\"agentScope\"}\",\n  \"expires_days\": ${\"agentExpiresDays\"},\n  \"step_up_token\": \"${getEntityById(\"9f91d9df-16d9-463b-98dd-383ad10a7939\").\"response\".\"body\".\"step_up_token\"}\"\n}"
            },
            "uri": {
              "query": {
                "delimiter": "&",
                "items": []
              },
              "host": "${\"AuthServer\"}",
              "path": "/agent"
            },
            "id": "42d953e2-59dc-47a9-8f90-6a0a6d095ed4",
            "name": "03. Create agent",
            "headers": [
              {
                "enabled": true,
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "entity": {
            "type": "Request",
            "method": {
              "requestBody": true,
              "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
              "name": "POST"
            },
            "body": {
              "bodyType": "Text",
              "textBody": "{\n  \"agent_id\": \"${getEntityById(\"42d953e2-59dc-47a9-8f90-6a0a6d095ed4\").\"response\".\"body\".\"agent_id\"}\",\n  \"agent_secret\": \"${getEntityById(\"42d953e2-59dc-47a9-8f90-6a0a6d095ed4\").\"response\".\"body\".\"agent_secret\"}\",\n  \"client_id\": \"${\"clientId\"}\",\n  \"scope\": \"${\"agentScope\"}\"\n}"
            },
            "uri": {
              "query": {
                "delimiter": "&",
                "items": []
              },
              "host": "${\"AuthServer\"}",
              "path": "/agent/token"
            },
