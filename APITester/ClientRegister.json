{
  "version": 6,
  "entities": [
    {
      "entity": {
        "type": "Project",
        "id": "5813650a-6733-42e9-807a-b60b79a27f26",
        "name": "AuthFoundation - ClientRegister"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "996eb369-6e78-40cc-9971-e4e543ccd995",
            "name": "ClientRegister",
            "description": "Registers an OIDC client, then uses the returned client_id in an authorization request."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "086eb887-8780-4f6f-87ff-f4479462efb0",
                "name": "01. Register client",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"client_name\": \"${\\\"ClientName\\\"}\",\n  \"client_type\": \"Public\",\n  \"redirect_uris\": [\n    \"${\\\"RedirectUri\\\"}\"\n  ],\n  \"scopes\": [\n    \"openid\",\n    \"email\",\n    \"profile\"\n  ],\n  \"data_keys\": [\n    \"email\",\n    \"name\",\n    \"picture\"\n  ]\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/client",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "enabled": true,
                    "name": "Authorization",
                    "value": "Bearer ${\"AdminAccessToken\"}"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "d0e0f041-7ab0-41da-a39f-a634d1c699e2",
                "name": "02. Start authorize with registered client",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/authorize",
                  "query": {
                    "delimiter": "&",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "response_type",
                        "value": "code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"AuthFoundation - ClientRegister\".\"01. Register client\".\"response\".\"body\".\"client_id\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"RedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "state",
                        "value": "${\"State\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "scope",
                        "value": "${\"Scope\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge_method",
                        "value": "S256"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge",
                        "value": "${\"CodeChallenge\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "nonce",
                        "value": "${\"Nonce\"}"
                      }
                    ]
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "x-auth-ui-response-mode",
                    "value": "json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "5ba34e8a-b808-40ed-add4-e3c3b62652da",
                "name": "03. Login for registered client authorize session",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": false,
                        "type": "Text",
                        "name": "request_id",
                        "value": "AuthRequestSessionId is carried by Set-Cookie from the authorize response."
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "email",
                        "value": "${\"Email\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "password",
                        "value": "${\"Password\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/login",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": false,
                    "name": "Cookie",
                    "value": "Chrome cookie jar carries AuthRequestSessionId from the authorize response. Do not set Cookie manually."
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "6bfe4fea-ee84-4f11-a73a-89528bfaa109",
                "name": "04. Exchange registered client authorization code",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "grant_type",
                        "value": "authorization_code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"AuthFoundation - ClientRegister\".\"01. Register client\".\"response\".\"body\".\"client_id\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"RedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code",
                        "value": "${\"AuthFoundation - ClientRegister\".\"03. Login for registered client authorize session\".\"response\".\"body\".\"authorization_code\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_verifier",
                        "value": "${\"CodeVerifier\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/token",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": true,
                    "name": "x-flow-type",
                    "value": "AuthorizationCode"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
  ],
