            "type": "Scenario",
            "id": "95fac247-e83b-489b-ba91-9dbd7edc5d4b",
            "name": "PasswordReset",
            "description": "Production password reset scenario using login email, registered birth date, and email code."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "f21a5b6c-9331-4eda-a8be-7de50936793f",
                "name": "01. Start password reset challenge",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\",\n  \"birth_date\": \"${\\\"BirthDate\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/password/reset/start",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "3f20b50a-7e26-4a0c-8a09-55f1c5d2f7a7",
                "name": "02. Complete password reset",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\",\n  \"birth_date\": \"${\\\"BirthDate\\\"}\",\n  \"email_code\": \"${\\\"EmailCode\\\"}\",\n  \"new_password\": \"${\\\"NewPassword\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/password/reset",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
