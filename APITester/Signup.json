{
  "version": 6,
  "entities": [
    {
      "entity": {
        "type": "Project",
        "id": "d3cbdafd-ab14-455c-b082-86aa796e9fa1",
        "name": "AuthFoundation - Signup"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "422c1f29-998f-491e-a464-4cc2adefd5fd",
            "name": "Signup",
            "description": "Production signup scenario: read current terms, create a user, then login through Authorization Code + PKCE."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "a4e839d4-3efd-4d05-b102-16cc7549928a",
                "name": "01. Get current terms",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/terms/current",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "88463158-726b-4b72-9578-000f93b22b7b",
                "name": "02. Create signup account",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"SignupEmail\\\"}\",\n  \"password\": \"${\\\"SignupPassword\\\"}\",\n  \"name\": \"${\\\"Name\\\"}\",\n  \"birth_date\": \"${\\\"BirthDate\\\"}\",\n  \"terms_accepted\": true,\n  \"accepted_terms_id\": \"${\\\"AuthFoundation - Signup\\\".\\\"01. Get current terms\\\".\\\"response\\\".\\\"body\\\".\\\"terms_id\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/signup",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "ce280394-d27a-4b37-8327-acd25147bbb3",
                "name": "03. Start authorize request for signup user",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/authorize",
                  "query": {
                    "delimiter": "&",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "response_type",
                        "value": "code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"ClientId\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"RedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "state",
                        "value": "${\"State\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "scope",
                        "value": "${\"Scope\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge_method",
                        "value": "S256"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge",
                        "value": "${\"CodeChallenge\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "nonce",
                        "value": "${\"Nonce\"}"
                      }
                    ]
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "x-auth-ui-response-mode",
                    "value": "json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "d0d7e003-7ce7-4c6d-83d7-350aa97d0a0a",
                "name": "04. Login with created signup user",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": false,
                        "type": "Text",
                        "name": "request_id",
                        "value": "AuthRequestSessionId is carried by Set-Cookie from the authorize response."
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "email",
                        "value": "${\"SignupEmail\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "password",
                        "value": "${\"SignupPassword\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/login",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": false,
                    "name": "Cookie",
                    "value": "Chrome cookie jar carries AuthRequestSessionId from the authorize response. Do not set Cookie manually."
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "9ce75316-3355-4a07-9d2c-41ff0240b43e",
                "name": "05. Exchange signup user authorization code",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "grant_type",
                        "value": "authorization_code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"ClientId\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"RedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code",
                        "value": "${\"AuthFoundation - Signup\".\"04. Login with created signup user\".\"response\".\"body\".\"authorization_code\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_verifier",
                        "value": "${\"CodeVerifier\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/token",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": true,
                    "name": "x-flow-type",
                    "value": "AuthorizationCode"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "c9bd9d15-08bc-41ab-89c7-f48d36bb0ac9",
                "name": "06. Get UserInfo for signup user",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/userinfo",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Authorization",
                    "value": "Bearer ${\"AuthFoundation - Signup\".\"05. Exchange signup user authorization code\".\"response\".\"body\".\"access_token\"}"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
