{
  "version": 6,
  "entities": [
    {
      "entity": {
        "type": "Project",
        "id": "428d5d60-d080-4c44-b43d-ea2fd41cb0dc",
        "name": "AuthFoundation - AgentDelegatedAuth"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "a77e3034-1bfa-4a9d-ae95-5b0bb669a44c",
            "name": "AgentDelegatedAuth",
            "description": "Production AI agent delegated auth scenario. MFA verify issues a step-up token, agent creation returns agent_secret, and token issuance consumes it."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "b287565b-2a47-4d05-af33-c424a116e037",
                "name": "01. Start email MFA",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"OwnerEmail\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/email/start",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "0075050f-f41c-407b-8253-7a032ffa4684",
                "name": "02. Verify email MFA",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"OwnerEmail\\\"}\",\n  \"code\": \"${\\\"EmailCode\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/email/verify",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "4615ef64-e6d3-4f12-ba4b-cd9d727740f7",
                "name": "03. Create agent delegation",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"owner_email\": \"${\\\"OwnerEmail\\\"}\",\n  \"agent_name\": \"${\\\"AgentName\\\"}\",\n  \"client_id\": \"${\\\"ClientId\\\"}\",\n  \"scope\": \"${\\\"AgentScope\\\"}\",\n  \"expires_days\": 30,\n  \"step_up_token\": \"${\\\"AuthFoundation - AgentDelegatedAuth\\\".\\\"02. Verify email MFA\\\".\\\"response\\\".\\\"body\\\".\\\"step_up_token\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/agent",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "9f5e9de3-6764-492e-8a8c-0d1fcd199975",
                "name": "04. Issue agent token",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"agent_id\": \"${\\\"AuthFoundation - AgentDelegatedAuth\\\".\\\"03. Create agent delegation\\\".\\\"response\\\".\\\"body\\\".\\\"agent_id\\\"}\",\n  \"agent_secret\": \"${\\\"AuthFoundation - AgentDelegatedAuth\\\".\\\"03. Create agent delegation\\\".\\\"response\\\".\\\"body\\\".\\\"agent_secret\\\"}\",\n  \"client_id\": \"${\\\"ClientId\\\"}\",\n  \"scope\": \"${\\\"AgentScope\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/agent/token",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
  ],
