        "name": "AuthFoundation - MfaStepUp"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "a393d0a0-cd5f-4b55-a873-3710c02704f3",
            "name": "MfaStepUp",
            "description": "Production MFA scenario. Enter the email verification code received by mail into the private EmailCode environment variable before running the verify step."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "2eb33af3-bcce-4834-b294-80aa66f61bd4",
                "name": "01. Start email MFA",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/email/start",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "350e4035-de96-47cc-855a-d7a8343a555d",
                "name": "02. Verify email MFA",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\",\n  \"code\": \"${\\\"EmailCode\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/email/verify",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "d4eb164b-23b4-4053-942f-0cb0eb7de0bd",
                "name": "03. Authenticator setup",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/authenticator/setup",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "19a1dc5a-7ea2-4fe4-a9b4-121b874ebefa",
                "name": "04. Verify authenticator code",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\",\n  \"code\": \"${\\\"TotpCode\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/authenticator/verify",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
