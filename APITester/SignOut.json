{
  "version": 6,
  "entities": [
    {
      "entity": {
        "type": "Project",
        "id": "9905cf1c-7304-4c86-95f1-8996749413e5",
        "name": "AuthFoundation - SignOut"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "069012fb-56df-480b-ad9e-6aa2e0b11792",
            "name": "SignOut",
            "description": "Production sign-out scenario: login, issue tokens, revoke access token, then logout."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "e7d796a5-4048-4351-91fe-4f28551e58d4",
                "name": "01. Start authorize request",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/authorize",
                  "query": {
                    "delimiter": "&",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "response_type",
                        "value": "code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"ClientId\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"RedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "state",
                        "value": "${\"State\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "scope",
                        "value": "${\"Scope\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge_method",
                        "value": "S256"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge",
                        "value": "${\"CodeChallenge\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "nonce",
                        "value": "${\"Nonce\"}"
                      }
                    ]
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "x-auth-ui-response-mode",
                    "value": "json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "c2777f9a-cb5e-4b45-822e-2aac56d85f5a",
                "name": "02. Login for authorize session",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": false,
                        "type": "Text",
                        "name": "request_id",
                        "value": "AuthRequestSessionId is carried by Set-Cookie from the authorize response."
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "email",
                        "value": "${\"Email\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "password",
                        "value": "${\"Password\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/login",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": false,
                    "name": "Cookie",
                    "value": "Chrome cookie jar carries AuthRequestSessionId from the authorize response. Do not set Cookie manually."
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "7f67906c-df09-4998-9bee-4bbeeecf94ff",
                "name": "03. Exchange authorization code",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "grant_type",
                        "value": "authorization_code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"ClientId\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"RedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code",
                        "value": "${\"AuthFoundation - SignOut\".\"02. Login for authorize session\".\"response\".\"body\".\"authorization_code\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_verifier",
                        "value": "${\"CodeVerifier\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/token",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": true,
                    "name": "x-flow-type",
                    "value": "AuthorizationCode"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "a7cf092b-972f-401c-abb3-c1d41648cbbb",
                "name": "04. Revoke issued access token",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "token",
                        "value": "${\"AuthFoundation - SignOut\".\"03. Exchange authorization code\".\"response\".\"body\".\"access_token\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/revoke",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "d5bef973-4952-4eca-8a88-77e792938018",
                "name": "05. Logout current auth session",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "logout_all",
                        "value": "false"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/logout",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
  ],
