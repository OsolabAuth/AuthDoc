        "id": "f33fc263-401f-4405-862f-b6acb5b8c273",
        "name": "AuthFoundation - PasswordChange"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "dcda2526-9d6d-476d-b4df-52286f69edf2",
            "name": "PasswordChange",
            "description": "Production password change scenario. The step-up token from MFA verify is used by the password change request."
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "b53d8e47-b510-41c3-9dec-475adac5cedf",
                "name": "01. Start email MFA",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/email/start",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "9cae17a2-1d48-4e8b-a024-494a78fa9dd7",
                "name": "02. Verify email MFA",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\",\n  \"code\": \"${\\\"AuthFoundation - PasswordChange\\\".\\\"01. Start email MFA\\\".\\\"response\\\".\\\"body\\\".\\\"code\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/mfa/email/verify",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "30933f4d-ab74-40cc-927b-ed126cefe217",
                "name": "03. Change password with step-up token",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Text",
                  "textBody": "{\n  \"email\": \"${\\\"Email\\\"}\",\n  \"current_password\": \"${\\\"CurrentPassword\\\"}\",\n  \"new_password\": \"${\\\"NewPassword\\\"}\",\n  \"step_up_token\": \"${\\\"AuthFoundation - PasswordChange\\\".\\\"02. Verify email MFA\\\".\\\"response\\\".\\\"body\\\".\\\"step_up_token\\\"}\"\n}"
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/account/password",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
  ],
