                "id": "4e1464b6-5ec3-499b-a52b-4d465c35405a",
                "name": "01. Portal authorize request",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/authorize",
                  "query": {
                    "delimiter": "&",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "response_type",
                        "value": "code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"PortalClientId\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"PortalRedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "state",
                        "value": "${\"State\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "scope",
                        "value": "${\"Scope\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge_method",
                        "value": "S256"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_challenge",
                        "value": "${\"CodeChallenge\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "nonce",
                        "value": "${\"Nonce\"}"
                      }
                    ]
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "x-auth-ui-response-mode",
                    "value": "json"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "d0660ec9-2916-475c-99e0-6525642eb3cb",
                "name": "02. Login for portal authorize session",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": false,
                        "type": "Text",
                        "name": "request_id",
                        "value": "AuthRequestSessionId is carried by Set-Cookie from the authorize response."
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "email",
                        "value": "${\"Email\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "password",
                        "value": "${\"Password\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/login",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": false,
                    "name": "Cookie",
                    "value": "Chrome cookie jar carries AuthRequestSessionId from the authorize response. Do not set Cookie manually."
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "c06bb9c0-0fc0-47e4-ad68-88df8661271a",
                "name": "03. Exchange portal authorization code",
                "method": {
                  "requestBody": true,
                  "link": "https://tools.ietf.org/html/rfc7231#section-4.3",
                  "name": "POST"
                },
                "body": {
                  "bodyType": "Form",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": [
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "grant_type",
                        "value": "authorization_code"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "client_id",
                        "value": "${\"PortalClientId\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "redirect_uri",
                        "value": "${\"PortalRedirectUri\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code",
                        "value": "${\"AuthFoundation - PortalLogin\".\"02. Login for portal authorize session\".\"response\".\"body\".\"authorization_code\"}"
                      },
                      {
                        "enabled": true,
                        "type": "Text",
                        "name": "code_verifier",
                        "value": "${\"CodeVerifier\"}"
                      }
                    ]
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/token",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  },
                  {
                    "enabled": true,
                    "name": "x-flow-type",
                    "value": "AuthorizationCode"
                  }
                ],
                "assertions": []
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "5001b299-271d-413c-82d9-f4e072ecddf5",
                "name": "04. Portal UserInfo",
                "method": {
                  "link": "http://tools.ietf.org/html/rfc7231#section-4.3.1",
                  "name": "GET"
                },
                "body": {
                  "bodyType": "Text",
                  "formBody": {
                    "overrideContentType": true,
                    "encoding": "application/x-www-form-urlencoded",
                    "items": []
                  }
                },
                "uri": {
                  "host": "${\"AuthServer\"}",
                  "path": "/userinfo",
                  "query": {
                    "delimiter": "&",
                    "items": []
                  }
                },
                "headers": [
                  {
                    "enabled": true,
                    "name": "Authorization",
                    "value": "Bearer ${\"AuthFoundation - PortalLogin\".\"03. Exchange portal authorization code\".\"response\".\"body\".\"access_token\"}"
                  }
                ],
                "assertions": []
              }
            }
          ]
        }
      ]
    }
